# Kopjoni si .env.local dhe vendosni vlerat nga Supabase Dashboard → Settings → API
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Përdorni një nga këto (anon / publishable — i njëjti çelës në dashboard):
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_key_here

# Opsionale — OCR faturave naftë
OPENAI_API_KEY=your_openai_api_key_here
