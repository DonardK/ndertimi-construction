# Kopjoni si .env.local

# OpenAI — OCR faturash (Nafta)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase — baza + sesioni i hyrjes (cookies)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_publishable_key

# Opsionale: nëse përdoruesi shkruan vetëm emrin pa @ në login
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=firma.local

# Sesion i gjatë: konfigurohet në Supabase Dashboard → Authentication → Settings
# (JWT expiry, session timeout, etj.) — shih dokumentacionin në përgjigjen e asistentit.
